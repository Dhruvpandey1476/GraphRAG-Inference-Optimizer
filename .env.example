# ─── TigerGraph Savanna ───────────────────────────────────────────
TIGERGRAPH_HOST=your-cluster.i.tgcloud.io
TIGERGRAPH_GRAPH=GraphRAGDemo
TIGERGRAPH_USERNAME=tigergraph
TIGERGRAPH_PASSWORD=your-password-here
TIGERGRAPH_SECRET=your-secret-here
TIGERGRAPH_PORT=443
TIGERGRAPH_USE_SSL=true

# ─── LLM (OpenAI) ────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ─── App Config ──────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_BASIC_RAG=5
MAX_HOPS_GRAPH_RAG=2
MAX_NEIGHBORS=10

