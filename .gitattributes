# Auto normalize line endings to LF
* text=auto

# Explicitly set line endings for common file types
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.html text eol=lf
*.css text eol=lf

# Binary files
*.pkl binary
*.db binary
*.sqlite binary
*.pickle binary

