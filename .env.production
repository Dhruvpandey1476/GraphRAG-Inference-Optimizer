# ============================================================================
# PRODUCTION ENVIRONMENT VARIABLES FOR RENDER.COM DEPLOYMENT
# ============================================================================
# 
# IMPORTANT: Add these as "Environment Variables" in Render dashboard:
# https://dashboard.render.com/services/[YOUR_SERVICE_ID]/environment
#
# DO NOT commit this file to GitHub if it contains real credentials.
# Use Render's environment variable manager for secrets.
#
# ============================================================================

# DEPLOYMENT ENVIRONMENT
ENVIRONMENT=production
LOG_LEVEL=info

# ============================================================================
# TIGERGRAPH CONFIGURATION
# ============================================================================
# These are for your existing cloud Savanna instance at:
# https://tgcloud.io
#
# To find these values:
# 1. Log in to TigerGraph Cloud Console
# 2. Go to your Savanna instance (tg-17b98dc4-8656...)
# 3. Click "Connect" → Copy connection details
#
TIGERGRAPH_HOST=tg-17b98dc4-8656-4f8d-bc0a-d30e8fdd5b27.tg-3452941248.i.tgcloud.io
TIGERGRAPH_GRAPH=GraphRAGDemo
TIGERGRAPH_USERNAME=tigergraph
TIGERGRAPH_PASSWORD=your-tigergraph-password-here
TIGERGRAPH_SECRET=your-tigergraph-secret-here

# ============================================================================
# GOOGLE GEMINI API CONFIGURATION
# ============================================================================
# Get your API key from: https://ai.google.dev/
#
# You should have ~$300 free credits. Monitor usage at:
# https://aistudio.google.com/app/apikeys
#
# WARNING: This key will be visible in environment variables.
# Set billing alerts to avoid surprise charges.
#
GOOGLE_API_KEY=your-google-gemini-api-key-here

# ============================================================================
# LLM & EMBEDDING MODELS
# ============================================================================
LLM_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-3-small

# ============================================================================
# DATA PATHS (for Render)
# ============================================================================
DATA_PATH=/var/data/arxiv_bulk
CACHE_DIR=/var/cache/graphrag

# ============================================================================
# OPTIONAL: CORS CONFIGURATION
# ============================================================================
CORS_ORIGINS=["https://your-domain.render.com", "http://localhost:5173"]

# ============================================================================
# OPTIONAL: PERFORMANCE TUNING
# ============================================================================
MAX_WORKERS=2
TIMEOUT_SECONDS=300
BATCH_SIZE=32

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
#
# Step 1: Prepare this file with your credentials
#
# Step 2: Add to Render Dashboard:
#   a) Go to https://dashboard.render.com
#   b) Select "GraphRAG Backend" service
#   c) Go to "Environment" tab
#   d) Add each variable above
#   e) Click "Save"
#
# Step 3: Manual Redeploy:
#   a) Go to "Deploys" tab
#   b) Click "Manual Deploy" or push to GitHub
#   c) Watch logs in "Logs" tab
#
# Step 4: Monitor Gemini API Usage:
#   - Each query costs ~$0.00015 (50 queries = ~$0.01)
#   - Check balance at: https://aistudio.google.com/app/apikeys
#
# Step 5: Test the deployment:
#   - Dashboard: https://graphrag-backend.render.com
#   - Health check: https://graphrag-backend.render.com/health
#   - Query API: POST https://graphrag-backend.render.com/query/compare
#
# ============================================================================
